# Normalize line endings for all text files
* text=auto

# Force LF for these file types (Linux/Docker compatibility)
*.py text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.md text eol=lf
*.txt text eol=lf
*.html text eol=lf
*.css text eol=lf
*.js text eol=lf
*.json text eol=lf
*.xml text eol=lf
*.sh text eol=lf
Dockerfile text eol=lf
.gitignore text eol=lf
.dockerignore text eol=lf

# Binary files — do not touch line endings
*.png binary
*.jpg binary
*.ico binary
*.woff binary
*.woff2 binary
*.ttf binary
*.otf binary
