# FlashiFi Configuration
# Copy to .env and modify as needed

# Application
FLASHIFI_DEBUG=false
FLASHIFI_LOG_LEVEL=INFO
FLASHIFI_HOST=0.0.0.0
FLASHIFI_PORT=8000
FLASHIFI_WORKERS=4
FLASHIFI_CORS_ORIGINS=["*"]

# Limits
FLASHIFI_MAX_DURATION_SECONDS=1200
FLASHIFI_MAX_FILE_SIZE_BYTES=104857600

# Storage (empty = OS temp directory)
FLASHIFI_TEMP_BASE_DIR=
FLASHIFI_CLEANUP_INTERVAL_SECONDS=300
FLASHIFI_CLEANUP_MAX_AGE_SECONDS=3600

# Tools
FLASHIFI_FFMPEG_PATH=ffmpeg

# Authentication (Bypasses YouTube bot verification checks)
# Use either a specific browser name ('chrome', 'edge', 'firefox', etc.)
# or a path to a cookies.txt file. Leave empty to disable authentication.
FLASHIFI_COOKIE_BROWSER=
FLASHIFI_COOKIE_FILE=

# Cache TTLs (seconds)
FLASHIFI_METADATA_CACHE_TTL=1800
FLASHIFI_SEARCH_CACHE_TTL=900
FLASHIFI_THUMBNAIL_CACHE_TTL=3600

# Search
FLASHIFI_MAX_SEARCH_RESULTS=10
FLASHIFI_DOWNLOAD_TIMEOUT=300
