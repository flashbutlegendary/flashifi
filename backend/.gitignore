# ──────────────────────────────────────────────────────────────
# FlashiFi — Python .gitignore
# ──────────────────────────────────────────────────────────────

# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class

# Distribution / packaging
dist/
build/
*.egg-info/
*.egg

# Virtual environments
venv/
.venv/
env/

# Environment variables
.env

# Testing
.pytest_cache/
htmlcov/
.coverage
.coverage.*
coverage.xml

# Type checking
.mypy_cache/

# Linting
.ruff_cache/

# Logs
logs/*.log

# Temporary files
temp/
tmp/
*.tmp

# IDE / editor files
.vscode/
.idea/
*.swp
*.swo
*~

# OS files
.DS_Store
Thumbs.db
